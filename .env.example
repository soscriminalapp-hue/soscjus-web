# ═══════════════════════════════════════════════════════════════════
#  SOSC JUS — Estação do Advogado
# ═══════════════════════════════════════════════════════════════════

# O backend. ⚠️ SEM o /api/v1 no fim — o proxy acrescenta.
SOSC_BACKEND_URL=https://api.soscriminalapp.com.br

# ⚠️ OBRIGATÓRIO. Gere com:  openssl rand -base64 48
# É o que cifra o cookie de sessão (AES-256-GCM).
SESSION_SECRET=

# ⚠️ A URL pública da estação. É ELA que vai no QR de recarga.
#    Sem isto, o QR aponta pro localhost e o celular não abre.
NEXT_PUBLIC_SITE_URL=https://web.soscjus.com.br

# As duas ferramentas satélite (elas já existem — a estação só linka).
FINAISJUS_URL=https://finaisjus.soscriminal.com.br
JURISCREATOR_URL=https://juriscreator.soscriminal.com.br

# Opcional — o nome do cookie.
# SESSION_COOKIE=soscjus_estacao
