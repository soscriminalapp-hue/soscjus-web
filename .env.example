# ══════════════════════════════════════════════════════════════
#  SOSC JUS · Estação do Advogado — variáveis de ambiente
#  Juliano: copie para .env.local (dev) ou configure na Vercel/VPS
# ══════════════════════════════════════════════════════════════

# ── BACKEND SOSC (obrigatório) ──────────────────────────────
# O mesmo backend do app. NÃO inclua /api/v1 no final.
SOSC_BACKEND_URL=https://api.soscriminalapp.com.br

# ── FINAISJUS PRO (obrigatório para a aba FinaisJus) ────────
FINAISJUS_URL=https://finaisjus.soscriminal.com.br

# ── JURISCREATOR (obrigatório para a aba JurisCreator) ──────
JURISCREATOR_URL=https://juriscreator.soscriminal.com.br

# ── SESSÃO (obrigatório) ────────────────────────────────────
# Segredo para assinar o cookie de sessão da estação.
# Gere com:  openssl rand -base64 48
SESSION_SECRET=troque-por-um-segredo-forte-de-48-bytes

# Nome do cookie (não precisa mudar)
SESSION_COOKIE=soscjus_estacao

# ── DEEP LINK DO APP (para o QR de compra avulsa) ───────────
APP_SCHEME=soscjus
APP_STORE_URL=https://apps.apple.com/app/id6770715490
PLAY_STORE_URL=https://play.google.com/store/apps/details?id=br.com.soscriminal.app

# ── OPCIONAL ───────────────────────────────────────────────
# Domínio público da estação (usado no QR e em redirects)
NEXT_PUBLIC_SITE_URL=https://estacao.soscjus.com.br
